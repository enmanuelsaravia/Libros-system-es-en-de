#!/bin/bash
case $# in
  2)
    INFILE=$1
    OUTFILE=$2
    ;;
  *)
    echo "USAGE: apertium-translate-to-default-equivalent INFILE OUTFILE";
    exit 1;
esac

xsltproc /home/user/Personal/Libros-aurelia/portable-bin-for-rocky-linux-8-PATH/share/apertium/translate-to-default-equivalent.xslt "$INFILE" > "$OUTFILE"
